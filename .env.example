# Template — copy to .env (gitignored) for local dev, or set as env vars in Railway.
# Never commit real secret values to this file or to .env.

# Fastmail JMAP API token. Generate at: Fastmail Settings → Security → API Tokens.
FASTMAIL_TOKEN=your-fastmail-api-token

# Telegram bot token from @BotFather (looks like "123456789:ABC-DEF...").
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# Your numeric Telegram user ID — the allowed-user gate ignores every other ID.
# Find yours by DM-ing @userinfobot.
TELEGRAM_ALLOWED_USER_ID=000000000

# Daily nudge time. Accepts HH:MM or HHMM (e.g., 16:00 or 1600).
# Leave empty / unset to disable the scheduled nudge entirely.
NUDGE_SCHEDULE=1600

# Local timezone for the scheduled nudge, as an IANA name. Railway defaults to
# UTC, so set this explicitly or the nudge fires at the wrong wall-clock hour.
TZ=America/New_York
